# Copy to .env on your VPS (same folder as docker-compose.yml):
#   cp .env.example .env && nano .env
# .env is gitignored — never commit real values.

# From Google Cloud → Google Auth Platform → Clients → your Web client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match the site URL (no trailing slash). OAuth redirect = {PUBLIC_BASE_URL}/auth/google/callback
PUBLIC_BASE_URL=https://stockscreenerx.com

# Random secret for session cookies, e.g. openssl rand -hex 32
SESSION_SECRET=

# true when users only reach the app over HTTPS (production behind Caddy)
SESSION_COOKIE_SECURE=true

# Comma-separated Google emails allowed to open /admin
ADMIN_EMAILS=nanjuauto1000@gmail.com,udayn612@gmail.com,pushpa.m.honnatti@gmail.com,plaxmi211@gmail.com,udayn582@gmail.com
